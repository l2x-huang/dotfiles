#!/bin/bash

set -e
cd "$(dirname "$0")/.."
DOTFILES_ROOT=$(pwd -P)
source "$DOTFILES_ROOT/install/log.sh"

if [[ "$OSTYPE" =~ ^darwin ]]; then
  fail 'os is macosx'
fi

source /etc/os-release
case $ID in
debian|ubuntu|devuan)
  sudo -E apt update && sudo -E apt upgrade -y
  ;;
arch|manjaro)
  yes | sudo -E pacman -Syu
  ;;
*)
  fail "$ID is not supported"
esac
